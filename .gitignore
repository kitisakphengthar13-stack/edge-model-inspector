__pycache__/
*.pyc
.venv/
venv/
env/

# Raw training/checkpoint files are usually large and should not be committed.
models/*
!models/.gitkeep
*.pt
*.pth
*.ckpt

# Generated deployment artifacts are ignored by default.
artifacts/*
!artifacts/.gitkeep

# Allow selected ONNX artifacts used for reproducible demos/tests.
!artifacts/simple_classifier_dryrun/
!artifacts/simple_classifier_dryrun/model.onnx
!artifacts/simple_classifier_dryrun/simple_classifier.onnx

# Do not commit target-specific TensorRT/build artifacts.
*.engine
*.plan
*.onnx.data

.DS_Store
